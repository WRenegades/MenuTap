page {
  background: #FFF5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  box-sizing: border-box;
}

view, scroll-view, swiper, text, image, button, input, textarea {
  box-sizing: border-box;
}

button {
  background: initial;
  margin: 0;
  padding: 0;
  line-height: 1.4;
}

button::after {
  border: none;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

.text-ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom, 12px);
}
