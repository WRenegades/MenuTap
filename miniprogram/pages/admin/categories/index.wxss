.page { min-height: 100vh; background: #FFF5F5; }

.no-permission {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 80vh;
}
.no-perm-icon { font-size: 100rpx; }
.no-perm-text { font-size: 36rpx; color: #333; margin-top: 20rpx; }

.header-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx; background: white; position: sticky; top: 0; z-index: 10;
}
.page-title { font-size: 28rpx; font-weight: 600; }
.add-btn {
  background: #FF6B81; color: white; font-size: 24rpx;
  padding: 12rpx 28rpx; border-radius: 30rpx;
}

.cat-list { padding: 0 20rpx 40rpx; }
.cat-item {
  display: flex; align-items: center; background: white;
  border-radius: 16rpx; padding: 20rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.cat-icon { font-size: 48rpx; margin-right: 16rpx; }
.cat-info { flex: 1; }
.cat-name { font-size: 28rpx; font-weight: 500; display: block; }
.cat-meta { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.cat-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: auto;
}
.action-btn {
  font-size: 22rpx;
  padding: 6rpx 0;
  border-radius: 16rpx;
  width: 64rpx;
  text-align: center;
  line-height: 1.4;
}
.action-btn.edit { background: #E3F2FD; color: #1976D2; }
.action-btn.del { background: #FFF0F2; color: #FF6B81; }

.empty-text { text-align: center; padding: 80rpx; color: #ccc; font-size: 26rpx; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200; display: none;
}
.modal-overlay.show { display: flex; align-items: flex-end; }

.form-panel {
  background: white; border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom, 20rpx));
  width: 100%;
}
.form-title { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.form-group { margin-bottom: 20rpx; }
.form-label { font-size: 26rpx; color: #555; display: block; margin-bottom: 6rpx; }
.form-input {
  background: #f5f5f5; border-radius: 12rpx; padding: 20rpx 24rpx;
  font-size: 26rpx; width: 100%; border: 1rpx solid #eee;
  line-height: 1.6; min-height: 72rpx;
}
.switch-group { display: flex; justify-content: space-between; align-items: center; }
.form-btns { display: flex; gap: 16rpx; margin-top: 30rpx; }
.btn-cancel, .btn-save {
  flex: 1; padding: 20rpx 0; border-radius: 30rpx; font-size: 28rpx; font-weight: 600;
}
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-save { background: #FF6B81; color: white; }
