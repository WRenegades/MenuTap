.page {
  min-height: 100vh;
  background: #FFF5F5;
}

.no-permission {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}
.no-perm-icon { font-size: 100rpx; }
.no-perm-text { font-size: 36rpx; color: #333; margin-top: 20rpx; }

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 10;
}
.page-title {
  font-size: 28rpx;
  font-weight: 600;
}
.add-btn {
  background: #FF6B81;
  color: white;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

.search-bar {
  padding: 0 20rpx 16rpx;
  background: white;
}
.search-input {
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  min-height: 72rpx;
}

.dish-list {
  padding: 0 20rpx 40rpx;
}
.dish-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.dish-media {
  flex-shrink: 0;
}
.dish-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}
.dish-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.dish-content {
  flex: 1;
  margin: 0 16rpx;
}
.dish-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dish-name {
  font-size: 28rpx;
  font-weight: 500;
}
.dish-status {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.dish-status.on { background: #E8F5E9; color: #4CAF50; }
.dish-status.off { background: #f5f5f5; color: #999; }
.dish-category {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.dish-price {
  font-size: 22rpx;
  color: #FF6B81;
  display: block;
  margin-top: 2rpx;
}
.dish-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
  align-items: flex-end;
}
.action-btn {
  font-size: 22rpx;
  padding: 6rpx 0;
  border-radius: 16rpx;
  width: 64rpx;
  text-align: center;
  line-height: 1.4;
}
.action-btn.edit { background: #E3F2FD; color: #1976D2; }
.action-btn.toggle.on { background: #E8F5E9; color: #4CAF50; }
.action-btn.toggle.off { background: #FFF0F2; color: #FF6B81; }

.empty-text { text-align: center; padding: 80rpx; color: #ccc; font-size: 26rpx; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200; display: none;
}
.modal-overlay.show { display: flex; align-items: flex-end; }

.form-panel {
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom, 20rpx));
  width: 100%;
  max-height: 85vh;
}
.form-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 24rpx;
}
.form-group {
  margin-bottom: 20rpx;
}
.form-label {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 6rpx;
}
.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  width: 100%;
  border: 1rpx solid #eee;
  line-height: 1.6;
  min-height: 72rpx;
}
.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  width: 100%;
  min-height: 120rpx;
  line-height: 1.5;
  border: 1rpx solid #eee;
}
.switch-group {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.picker-box {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #eee;
}
.upload-btn {
  background: #FFF0F2;
  color: #FF6B81;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 12rpx;
  display: inline-block;
  border: 1rpx dashed #FF6B81;
}
.preview-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}
.form-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}
.btn-cancel, .btn-save {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-save { background: #FF6B81; color: white; }
