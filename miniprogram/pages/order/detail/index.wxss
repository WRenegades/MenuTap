.detail-page {
  min-height: 100vh;
  background: #FFF5F5;
}

/* ====== 菜品详情 ====== */
.dish-banner {
  width: 100%;
  height: 500rpx;
}
.dish-banner-placeholder {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, #FFE0E6, #FFF0F2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-icon {
  font-size: 120rpx;
}
.dish-body {
  padding: 30rpx;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  margin-top: -30rpx;
  position: relative;
}
.dish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}
.dish-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
.dish-price {
  font-size: 36rpx;
  color: #FF6B81;
  font-weight: 700;
  margin-top: 12rpx;
  display: block;
}
.info-section {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #FFF9FA;
  border-radius: 16rpx;
}
.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B81;
  display: block;
  margin-bottom: 8rpx;
}
.section-text {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-top: 6rpx;
  line-height: 1.6;
}
.back-btn {
  width: 100%;
  margin-top: 40rpx;
  background: #FF6B81;
  color: white;
  font-size: 28rpx;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-weight: 600;
}
.back-btn:active {
  opacity: 0.8;
}

/* ====== 订单详情 ====== */
.order-status-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: white;
}
.status-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}
.status-info {
  display: flex;
  flex-direction: column;
}
.status-text {
  font-size: 36rpx;
  font-weight: 600;
}
.status-time {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.order-items {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 20rpx;
}
.order-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.order-item:last-child {
  border-bottom: none;
}
.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}
.item-img-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.item-info {
  flex: 1;
  margin-left: 16rpx;
}
.item-name {
  font-size: 28rpx;
  font-weight: 500;
}
.item-spec {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.item-remark {
  font-size: 22rpx;
  color: #FF6B81;
  display: block;
  margin-top: 2rpx;
}
.item-qty {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.order-footer {
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 20rpx;
}
.order-no {
  font-size: 24rpx;
  color: #999;
}
.order-total {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B81;
  margin-top: 8rpx;
}

/* 管理员操作 */
.admin-actions {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 20rpx;
}
.action-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}
.action-btns {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}
.action-btn {
  background: #FFF0F2;
  color: #FF6B81;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #FFE0E6;
}
.action-btn[disabled] {
  opacity: 0.4;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #ccc;
  font-size: 28rpx;
}
